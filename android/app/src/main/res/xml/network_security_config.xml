<?xml version="1.0" encoding="utf-8"?>
<!-- Production/provider traffic stays HTTPS-only; plain HTTP is permitted ONLY
     to the local MNN dev server (the WSA host gateway + loopback) so the app can
     reach http://<host>:8080/v1 during on-device E2E testing.
     The host IP is patched by tool/wsa/run_e2e.sh to match WSA's gateway. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false"/>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">172.29.224.1</domain> <!-- WSA_HOST -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
